---
import { t, getLanguage } from '@Grow Tales/common/i18n';

let currentLanguage = getLanguage(),
    languages = [
        { locale: 'en', name: 'English' },
        { locale: 'de', name: 'Deutsch' },
        { locale: 'es', name: 'Español' },
        { locale: 'fr', name: 'Français' },
        { locale: 'pt', name: 'Português' },
        { locale: 'ro', name: 'Română' },
        { locale: 'ru', name: 'Русский' },
        { locale: 'tl', name: 'Tagalog'}
    ];
---

<div id="intro">
    <section id="parchment" class="load-character slice-menu-fancy">
        <article id="load-character">
            <h1 class="title-decoration">Grow Tales</h1>

            <form onsubmit={'return false'}>
                <input type="hidden" id="login-name-input" class="stroke slice-input" name="player-name" value="" />
                <input type="hidden" id="login-password-input" class="stroke slice-input" name="player-password" value="" />

                <div class="validation-summary"></div>

                <div class="button-row" style="justify-content: center; margin-top: 10px;">
                    <button
                        title="Play"
                        aria-label="Play"
                        type="button"
                        id="play-button"
                        class="stroke slice-button"
                    >
                        PLAY
                    </button>
                    <!-- Keep the actual submit button hidden, we will trigger it programmatically or repurpose it -->
                    <button
                        title="Login"
                        aria-label="Login"
                        type="submit"
                        id="login"
                        class="stroke slice-button"
                        style="display: none;"
                    >
                        LOGIN
                    </button>
                </div>
            </form>
        </article>

        <article id="create-character">
            <h1 class="title-decoration">New Character</h1>

            <form onsubmit={'return false'}>
                <input
                    type="text"
                    id="register-name-input"
                    class="stroke slice-input"
                    name="player-name"
                    placeholder="Username"
                    aria-label="Username"
                    maxlength="32"
                    autocomplete="off"
                />
                <input
                    type="password"
                    id="register-password-input"
                    class="stroke slice-input"
                    name="player-password"
                    placeholder="Password"
                    aria-label="Password"
                    maxlength="64"
                    autocomplete="off"
                />
                <input
                    type="password"
                    id="register-password-confirmation-input"
                    class="stroke slice-input"
                    name="player-password2"
                    placeholder="Confirm Password"
                    aria-label="Confirm Password"
                    maxlength="64"
                    autocomplete="off"
                />
                <input
                    type="email"
                    id="register-email-input"
                    class="stroke slice-input"
                    name="player-email"
                    placeholder="Email Address"
                    aria-label="Email Address"
                    maxlength="64"
                    autocomplete="off"
                />

                <div class="validation-summary"></div>

                <div class="button-row">
                    <button
                        title="Cancel"
                        aria-label="Cancel"
                        type="button"
                        id="cancel-register"
                        class="stroke slice-button"
                    >
                        CANCEL
                    </button>
                    <button
                        title="Play"
                        aria-label="Play"
                        type="submit"
                        id="play"
                        class="stroke slice-button"
                    >
                        PLAY
                    </button>
                </div>
            </form>
        </article>

        <article id="reset-password">
            <h1 class="title-decoration">Reset Password</h1>

            <form onsubmit={'return false'}>
                <input
                    type="text"
                    id="email-reset-input"
                    class="stroke slice-input"
                    name="player-email"
                    placeholder="Email Address"
                    aria-label="Email Address"
                    maxlength="32"
                    autocomplete="off"
                />

                <div class="validation-summary"></div>

                <div class="button-row">
                    <button
                        title="Cancel"
                        aria-label="Cancel"
                        type="button"
                        id="cancel-forget"
                        class="stroke slice-button"
                    >
                        CANCEL
                    </button>
                    <button
                        title="Submit"
                        aria-label="Submit"
                        type="submit"
                        id="continue-forget"
                        class="stroke slice-button"
                    >
                        CONTINUE
                    </button>
                </div>
            </form>
        </article>

        <article id="world-select">
            <h1>
                <span class="left-ornament"></span>
                 World Select
                <span class="right-ornament"></span>
            </h1>

            <form onsubmit={'return false'}>
                <ol id="worlds"></ol>

                <div class="button-row">
                    <button
                        title="Cancel"
                        aria-label="Cancel"
                        type="button"
                        id="cancel-worlds"
                        class="stroke slice-button"
                    >
                        CANCEL
                    </button>
                    <button
                        title="Continue"
                        aria-label="Continue"
                        type="submit"
                        id="continue-worlds"
                        class="stroke slice-button"
                    >
                        CONTINUE
                    </button>
                </div>
            </form>
        </article>

        <article id="credits">
            <h1 class="title-decoration">Credits</h1>

            <p>
                <br />
                 Special thanks to
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://www.littleworkshop.fr/">Little Workshop</a
                >
                 for the pixel art,
                <br />
                <br />
                 and the Asky Team.
                <br />
                <br />
                 More pixel assets by
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://opengameart.org/users/buch">Buch</a
                >,
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://shikashiassets.itch.io/shikashis-fantasy-icons-pack">Shikashi</a
                >,
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://opengameart.org/content/kyrises-free-16x16-rpg-icon-pack"
                    >Kyrise</a
                >,
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://game-icons.net">Game-Icons.net</a
                >, &amp; Boo
                <br />
                <br />
                 Music by
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://soundcloud.com/gyrowolf">Terrel O'Brien</a
                >,
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://blog.dayjo.org">Joel Day</a
                >,
                <a
                    rel="noopener noreferrer"
                    class="clickable"
                    target="_blank"
                    href="https://www.dantilden.com">Dan Tilden</a
                >, &amp;
                <a
                    rel="noopener noreferrer"
                    target="_blank"
                    class="clickable"
                    href="https://soundcloud.com/aaron-anderson-11">Aaron Krogh</a
                >
            </p>

            <div class="close-about">
                <span>-- Click anywhere to close --</span>
            </div>
        </article>

        <article id="about">
            <h1 class="title-decoration">About</h1>

            <p>
                Grow Tales is a browser-based 2D MMORPG adventure. You play as an adventurer amongst
                others and explore the world of Grow Tales. Originally started as a fork of
                BrowserQuest, Grow Tales has evolved into its own game. In honour to the original idea,
                the assets have been preserved and expanded upon. We are one of a few open-source
                community driven game projects. We are always looking for assistance in terms of
                programming, graphic artists, and/or music composers. Our source-code can be found
                on our
                <a target="_blank" href="https://github.com/Grow Tales/Grow Tales-Open"
                    >GitHub Repository</a
                >. If you would like to stay up-to-date with the project, make sure you join our
                <a target="_blank" href="https://discord.gg/MmbGAaw">Discord server</a>.
            </p>

            <div class="close-about">
                <span>-- Click anywhere to close --</span>
            </div>
        </article>

        <article id="git">Structure this later</article>

        <article id="death">
            <h1>You have died...</h1>
            <button
                title="Respawn"
                id="respawn"
                title="Respawn"
                aria-label="Respawn"
                class="stroke slice-button">RESPAWN</button
            >
        </article>

        <span class="loader" hidden>
            Connecting<span class="loader-dot">.</span><span class="loader-dot">.</span><span
                class="loader-dot">.</span
            >
        </span>
    </section>

    <select id="lang-select" oninput={'location = "/" + this.value + "/"'}>
        {
            languages.map(({ locale, name }) => (
                <option value={locale} selected={locale === currentLanguage}>
                    {name}
                </option>
            ))
        }
    </select>

    <button id="world-select-button" class="slice-button" hidden>
        <strong class="stroke"></strong>
        <span class="stroke"></span>
    </button>

    <span id="game-version" class="version"></span>

    <a href="https://twitter.com/" target="_blank" rel="noopener noreferrer" id="twitter-button" class="slice-button stroke" style="position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); text-decoration: none; padding: 10px 20px; background-color: #1DA1F2; color: white; display: flex; align-items: center; justify-content: center; border-radius: 5px; gap: 8px; font-size: 14px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"/>
        </svg>
        Twitter
    </a>
</div>
